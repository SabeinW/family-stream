# Copy this to .env before running `docker compose up -d --build`
# Copy this to .env before running `docker compose up -d --build`
JWT_SECRET=replace-with-a-long-random-string

# For a VPS deploy with a real domain (enables automatic HTTPS via Caddy):
DOMAIN=family.yourdomain.com
CLIENT_ORIGIN=https://family.yourdomain.com

# Only used by docker-compose.local.yml (no domain / localhost testing):
HOST_PORT=8080

# Optional: powers the TMDB movie/show catalog feature once it's built.
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

