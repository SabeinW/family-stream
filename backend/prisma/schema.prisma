// Prisma schema for FamilyStream
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  username     String?   @unique // optional, lowercase-normalized; lets friends be added without knowing an email
  passwordHash String
  createdAt    DateTime  @default(now())
  profiles     Profile[]
  media        Media[]
  mediaShares  MediaShare[]
  playlists      Playlist[]
  playlistShares PlaylistShare[]

  friendRequestsSent     Friendship[] @relation("Requester")
  friendRequestsReceived Friendship[] @relation("Addressee")
}

// Friend connection between two accounts. `pairKey` is a canonicalized,
// order-independent key (min(id,id):max(id,id)) computed by the route
// handler before writing, so A->B and B->A can never both exist as separate
// rows — a plain @@unique([requesterId, addresseeId]) only blocks one order.
model Friendship {
  id          String   @id @default(uuid())
  requester   User     @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String
  addressee   User     @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  addresseeId String
  status      String   @default("pending") // pending | accepted
  pairKey     String
  createdAt   DateTime @default(now())

  @@unique([pairKey])
  @@index([status])
  @@index([requesterId])
  @@index([addresseeId])
}

model Profile {
  id          String     @id @default(uuid())
  name        String
  avatarColor String     @default("#E50914")
  avatarPath  String?    // uploaded profile photo filename; falls back to the color+initial avatar when unset
  isKid       Boolean    @default(false)
  pinHash     String?    // optional PIN for kid/locked profiles
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  favorites   Favorite[]
  progress    WatchProgress[]
  createdAt   DateTime   @default(now())
}

model Media {
  id             String     @id @default(uuid())
  title          String
  description    String?
  type           String     // "video" | "photo"
  category       String     @default("Uncategorized") // e.g. "Vacations", "Memories"
  tags           String     @default("") // comma-separated
  originalPath   String
  streamPath     String?    // default/highest-quality rendition filename (videos only)
  thumbnailPath  String?
  durationSec    Int?
  width          Int?
  height         Int?
  status         String     @default("processing") // processing | ready | failed
  uploadedBy     String?
  takenAt        DateTime?  // capture date, for "Memories from 1 year ago"
  createdAt      DateTime   @default(now())
  favorites      Favorite[]
  progress       WatchProgress[]
  renditions     VideoRendition[]
  playlistItems  PlaylistItem[]

  // Ownership & sharing. ownerId is nullable only to survive the first
  // `prisma db push` against pre-existing rows — backfillOwners.js sets it
  // from `uploadedBy` automatically on every boot. NULL is treated as
  // visible-to-everyone (fail-open) in access.js so nothing gets locked out
  // during that backfill window; SQLite has no enum type, so `visibility`
  // is validated in application code, not the schema.
  ownerId    String?
  visibility String       @default("private") // private | friends | custom
  owner      User?        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  shares     MediaShare[]

  @@index([ownerId])
  @@index([visibility])
}

// Explicit per-user share grant, used when Media.visibility === "custom".
model MediaShare {
  id        String   @id @default(uuid())
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([mediaId, userId])
  @@index([userId])
}

// One row per encoded quality level (adaptive-quality selector on the frontend).
model VideoRendition {
  id        String   @id @default(uuid())
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId   String
  quality   String   // "1080p" | "720p" | "480p"
  path      String   // filename within uploads/transcoded
  bitrate   Int?      // kbps, informational
  height    Int
  createdAt DateTime @default(now())

  @@unique([mediaId, quality])
}

model Favorite {
  id        String   @id @default(uuid())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId   String
  createdAt DateTime @default(now())

  @@unique([profileId, mediaId])
}

model WatchProgress {
  id           String   @id @default(uuid())
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId    String
  media        Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId      String
  positionSec  Float    @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([profileId, mediaId])
}

model Playlist {
  id         String          @id @default(uuid())
  name       String
  owner      User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId    String
  visibility String          @default("private") // private | friends | custom
  coverColor String          @default("99 102 241") // "R G B" — owner-selectable accent for the playlist's card
  items      PlaylistItem[]
  shares     PlaylistShare[]
  createdAt  DateTime        @default(now())

  @@index([ownerId])
  @@index([visibility])
}

model PlaylistItem {
  id         String   @id @default(uuid())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playlistId String
  media      Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId    String
  addedAt    DateTime @default(now())

  @@unique([playlistId, mediaId])
}

// Explicit per-user share grant, used when Playlist.visibility === "custom".
model PlaylistShare {
  id         String   @id @default(uuid())
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playlistId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime @default(now())

  @@unique([playlistId, userId])
  @@index([userId])
}
